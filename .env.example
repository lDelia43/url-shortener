# --- Database ---
# Postgres connection string. Locally (db via docker compose) use host=localhost.
# The connection_limit parameter right-sizes the Prisma pool (defensive design).
DATABASE_URL="postgresql://url_user:url_pass@localhost:5432/url_shortener?schema=public&connection_limit=10"

# --- HTTP server ---
# Port the back-end listens on.
PORT=3000

# --- Base URL ---
# Prefix used to build the shortUrl in the POST /shorten response.
# Must point to the service's public host (no trailing slash).
BASE_URL="http://localhost:3000"
